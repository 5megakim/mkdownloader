{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MK 유튜브 다운로더",
  "mainBinaryName": "MKDownloader",
  "version": "1.0.2",
  "identifier": "com.megakim.youtubedownloader",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MK 유튜브 다운로더",
        "width": 760,
        "height": 920,
        "minWidth": 640,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "startMenuFolder": "MK Vibe"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
